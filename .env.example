# Storage details
# Subscription id, resource group name, location, AKS cluster name, storage account name and container name
SUBSCRIPTION="68e5d74d-cc6b-4be6-9606-cd1c77fa55f0"
RG="vibhansa-ray-aks-rg"
LOC="swedencentral"
AKS="vibhansa-ray-aks"
#SA="vibhansaraystorage"
SA="vibhansaanyscalestorage"
CONTAINER="datasets"

# Cluster Configuration
# GPU based cluster or not, node count, cpu or gpu based node type
GPU=false
NodeCount=25
VmType="Standard_D48ds_v5"
#VmType="Standard_D4_v2"
#VmType="Standard_NC6s_v3"

# Ray Configuration
# Number of workers in the pool and number of nodes to be used to run that pool
# IMPORTANT: For 23 × D48ds_v5 nodes (48 vCPU, 192GB RAM each):
#   - WORKER_REPLICAS = 40 (pod replicas for workers)
#   - NUM_WORKERS = 40 (model shards distributed across worker pods)
#   - Per worker: 22 vCPU / 90GB RAM (2 workers per node max)
#   - Each pod requests 22vCPU / 90GB, limits 24vCPU / 96GB
WORKER_REPLICAS=20
NUM_WORKERS=20

# Mount Path Configuration
# These paths define where storage will be mounted in Ray containers
# Customize these paths based on your application requirements
DATA_DIR="/mnt/blob/datasets"
CHECKPOINT_DIR="/mnt/blob/checkpoints"
APP_DIR="/app"
CACHE_DIR="/mnt/blobfusecache"
CHECKPOINT_CACHE="/mnt/blobfusecache_ckpt"

# Preprocessing Configuration
#
# Change to "k8s/rayjob-dataprep-adlfs.yaml" for ADLFS-based preprocessing
DATAPREP_RAY_CONFIG="k8s/rayjob-dataprep.yaml"
DATAPREP_JOB_NAME="data-prep-job"

# ADLFS specific preprocessing configurations
#
# ADLFS setup uses account key for authentication. Add account key here before running Ray job
# STORAGE_ACCOUNT_KEY="3482HaivQ9tinCwoXrXDxeFgqpLQdaCIMfNUeTtVgfhOuxd83CZHYhrSMxsemee7NBSFrdlRsmn5+AStw/DOrQ=="
STORAGE_ACCOUNT_KEY=""
# The number of preprocess tasks running concurrently at each stage of the data pipeline. On average each,
# .arrow file is +200MB and there are 3 stages in the pipeline (read, convert to arrow table, write) where each input
# and output will be roughly the same size. Setting  a max concurrency to 2 will mean there will be no more than 2 read,
# 2 convert, and 2 write tasks running at once, helping to limit memory overall memory usage.
MAX_PREPROCESS_TASK_CONCURRENCY=2


HF_TOKEN=""

# Anyscale CLI configuration
# ANYSCALE_CLI_TOKEN="aph0_CkcwRQIhAOQMnNBeN5dfO2IdlAQB1yHepoI4RavjNAC0IhwneGyFAiBXg3FVMOjpzRXQC56sIGV3onFahNSrVrf-74ZXfJ0wVhJjEiB8mFajCqNqeB8zESO_U-CxRdOBhRBjc9btxyahNMYYgRgBIh51c3JfajdzZTk5ZW05eDUxc24ycW0ybmtzZTgzczM6DAiujsrNBhCYpMy6A0IMCILyq8wGEJikzLoD8gEA"
ANYSCALE_CLI_TOKEN=""
ANYSCALE_HOST="https://console.azure.anyscale.com"
ANYSCALE_AUTO_CLI_LOGIN="true"    # If token is missing/invalid, run `anyscale login` interactively
ANYSCALE_CLOUD_NAME=""

# Optional Anyscale K8s cloud setup overrides
# Namespace for the Anyscale operator
ANYSCALE_NAMESPACE="anyscale-system"
# Path to write the Helm values emitted by `anyscale cloud setup`
ANYSCALE_VALUES_FILE="anyscale-operator-values.yaml"
# Helm chart settings for the operator
ANYSCALE_HELM_REPO="https://charts.anyscale.com"
ANYSCALE_HELM_RELEASE="anyscale-operator"
# PVC name to register for shared storage (if registering cloud resources)
ANYSCALE_PVC="blob-pvc-checkpoint"
# Comma-separated k8s zones (if applicable)
ANYSCALE_K8S_ZONES="1,2,3"
# Optional: federated identity for the Anyscale operator service account
ANYSCALE_OPERATOR_IDENTITY=""
# Workspace pods commonly run as default SA; keep this aligned if your templates use a different SA
ANYSCALE_WORKSPACE_SERVICE_ACCOUNT="default"
ANYSCALE_OPERATOR_CHART_VERSION="1.4.0"
# Toggles to control setup script behavior
ANYSCALE_DO_SETUP="false"          # Keep false; Anyscale CLI tool check is flaky on Windows
ANYSCALE_INSTALL_OPERATOR="true"   # Attempts operator install; will warn if Helm fails
ANYSCALE_REGISTER_CLOUD="true"     # Leave true to ensure the cloud is registered
ANYSCALE_STRICT_LIFECYCLE="true" # true => abort if delete fails or cloudDeploymentId cannot be resolved/persisted
